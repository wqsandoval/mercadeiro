DATABASE_URL="postgresql://mercadeiro:mercadeiro@localhost:5432/mercadeiro?schema=public"
PORT=3333
HOST=0.0.0.0

# Limiares do Analítico (RN-06.2 / RN-06.3) — placeholders, calibrar com dados reais de uso
PRICE_ALERT_THRESHOLD_PERCENT=18
ABSENCE_ALERT_WEEKS=6

# Geocoding (camada abstraída — ver src/geocoding)
GEOCODING_PROVIDER=nominatim
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"

# Autenticação por bearer token único (app single-user, sem contas). Exigido em
# todas as rotas exceto /health. Gere um novo com: openssl rand -hex 32
API_BEARER_TOKEN=changeme-gere-um-token-local-com-openssl-rand--hex-32

# CORS: origens permitidas, separadas por vírgula. "*" (padrão) reflete a
# origem da requisição — ok em dev. Em produção, restrinja ao domínio do
# frontend, ex: https://app.seudominio.com
CORS_ORIGIN=*
