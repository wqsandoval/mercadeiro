# Copie para .env.prod na VPS (nunca commitar o .env.prod real).
# Uso: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# --- Domínios / Traefik ---
# Sem domínio definido ainda? Preencha estes 3 antes do primeiro deploy.
DOMAIN_API=api.seudominio.com
DOMAIN_FRONTEND=app.seudominio.com
# Nome da rede Docker externa onde o Traefik já roda na VPS.
TRAEFIK_NETWORK=traefik-public
# Precisam bater com o que já está configurado no Traefik da VPS.
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Backend ---
# Postgres externo/gerenciado — este stack não sobe banco.
DATABASE_URL="postgresql://usuario:senha@host:5432/mercadeiro?schema=public&sslmode=require"

# Autenticação por bearer token único (app single-user). Gere com: openssl rand -hex 32
API_BEARER_TOKEN=changeme-gere-um-token-com-openssl-rand--hex-32

# CORS: só a origem do frontend em produção (sem "*").
CORS_ORIGIN=https://app.seudominio.com

# Limiares do Analítico (RN-06.2 / RN-06.3) — placeholders, calibrar com dados reais de uso
PRICE_ALERT_THRESHOLD_PERCENT=18
ABSENCE_ALERT_WEEKS=6

# Geocoding (camada abstraída — ver backend/src/geocoding)
GEOCODING_PROVIDER=nominatim
NOMINATIM_BASE_URL="https://nominatim.openstreetmap.org"
